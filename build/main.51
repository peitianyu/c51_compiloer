    TR0=0;
    ET0=0;
}
void PWM_SetChannel(unsigned char ch, unsigned int val)
{
    if ((ch>=8))
        return;
    if ((val>1023))
        val=1023;
    CH_data[ch]=val;
}
void PWM_SetFailsafe(unsigned char ch, unsigned int val)
{
    if ((ch>=8))
        return;
    if ((val>1023))
        val=1023;
    CH_failsafe[ch]=val;
}
void T0_ISR() interrupt 1
{
    TL0=32;
    TH0=254;
    t_output++;
    switch (t_output)
{
case 1:
        CH1_PIN=1;
        temp2=(1024-temp1);
        TL0=(unsigned char)temp2;
        TH0=(unsigned char)(temp2>>8);
        break;
case 2:
        CH1_PIN=0;
        temp1=(66000-(CH_data[0]*27/20));
        TL0=(unsigned char)temp1;
        TH0=(unsigned char)(temp1>>8);
        break;
case 3:
        CH2_PIN=1;
        temp2=(1024-temp1);
        TL0=(unsigned char)temp2;
        TH0=(unsigned char)(temp2>>8);
        break;
case 4:
        CH2_PIN=0;
        temp1=(66000-(CH_data[1]*27/20));
        TL0=(unsigned char)temp1;
        TH0=(unsigned char)(temp1>>8);
        break;
case 5:
        CH3_PIN=1;
        temp2=(1024-temp1);
        TL0=(unsigned char)temp2;
        TH0=(unsigned char)(temp2>>8);
        break;
case 6:
        CH3_PIN=0;
        temp1=(66000-(CH_data[2]*27/20));
        TL0=(unsigned char)temp1;
        TH0=(unsigned char)(temp1>>8);
        break;
case 7:
        CH4_PIN=1;
        temp2=(1024-temp1);
        TL0=(unsigned char)temp2;
        TH0=(unsigned char)(temp2>>8);
        break;
case 8:
        CH4_PIN=0;
        temp1=(66000-(CH_data[3]*27/20));
        TL0=(unsigned char)temp1;
        TH0=(unsigned char)(temp1>>8);
        break;
case 9:
        CH5_PIN=1;
        temp2=(1024-temp1);
        TL0=(unsigned char)temp2;
        TH0=(unsigned char)(temp2>>8);
        break;
case 10:
        CH5_PIN=0;
        temp1=(66000-(CH_data[4]*27/20));
        TL0=(unsigned char)temp1;
        TH0=(unsigned char)(temp1>>8);
        break;
case 11:
        CH6_PIN=1;
        temp2=(1024-temp1);
        TL0=(unsigned char)temp2;
        TH0=(unsigned char)(temp2>>8);
        break;
case 12:
        CH6_PIN=0;
        temp1=(66000-(CH_data[5]*27/20));
        TL0=(unsigned char)temp1;
        TH0=(unsigned char)(temp1>>8);
        break;
case 13:
        CH7_PIN=1;
        temp2=(1024-temp1);
        TL0=(unsigned char)temp2;
        TH0=(unsigned char)(temp2>>8);
        break;
case 14:
        CH7_PIN=0;
        temp1=(66000-(CH_data[6]*27/20));
        TL0=(unsigned char)temp1;
        TH0=(unsigned char)(temp1>>8);
        break;
case 15:
        CH8_PIN=1;
        temp2=(1024-temp1);
        TL0=(unsigned char)temp2;
        TH0=(unsigned char)(temp2>>8);
        break;
case 16:
        CH8_PIN=0;
        temp1=(66000-(CH_data[0]*27/20));
        TL0=(unsigned char)temp1;
        TH0=(unsigned char)(temp1>>8);
        t_output=0;
        break;
    }
}
static xdata unsigned char current_addr[5];
static unsigned char spi_rw(unsigned char byte)
{
    unsigned char i;
    for (i=0; (i<8); i++)
        {
            if ((byte&128))
                NRF_MOSI=1;
            else
                NRF_MOSI=0;
            NRF_SCK=1;
            byte<<=1;
            byte|=1;
            NRF_SCK=0;
        }
    return byte;
}
static void reg_write(unsigned char reg, unsigned char val)
{
    NRF_CSN=0;
    spi_rw((32|reg));
    spi_rw(val);
    NRF_CSN=1;
}
static unsigned char reg_read(unsigned char reg)
{
    unsigned char val;
    NRF_CSN=0;
    spi_rw((0|reg));
    val=spi_rw(255);
    NRF_CSN=1;
    return val;
}
static void fifo_write(unsigned char *buf, unsigned char len)
{
    unsigned char i;
    NRF_CSN=0;
    spi_rw(160);
    for (i=0; (i<len); i++)
        spi_rw(buf[i]);
    NRF_CSN=1;
}
static void fifo_read(unsigned char *buf, unsigned char len)
{
    unsigned char i;
    NRF_CSN=0;
    spi_rw(97);
    for (i=0; (i<len); i++)
        buf[i]=spi_rw(255);
    NRF_CSN=1;
}
void NRF_Init()
{
    do
        {
            P1M0|=(1<<3);
            P1M1&=~(1<<3);
        }
    while (0);
    do
        {
            P1M0&=~(1<<4);
            P1M1&=~(1<<4);
        }
    while (0);
    do
        {
            P1M0|=(1<<5);
            P1M1&=~(1<<5);
        }
    while (0);
    do
        {
            P2M0|=(1<<0);
            P2M1&=~(1<<0);
        }
    while (0);
    do
        {
            P2M0|=(1<<1);
            P2M1&=~(1<<1);
        }
    while (0);
    do
        {
            P2M0&=~(1<<2);
            P2M1&=~(1<<2);
        }
    while (0);
    NRF_CE=0;
    NRF_SCK=0;
    NRF_CSN=1;
    reg_write(0, 10);
    reg_write(1, 0);
    reg_write(2, 1);
    reg_write(4, 0);
    reg_write(7, 112);
    reg_write(5, 66);
    reg_write(17, 11);
    NRF_SetPower(3);
    NRF_SetRxMode();
}
unsigned char NRF_Test()
{
    unsigned char status;
    status=reg_read(7);
    if (((status&15)!=14))
        return 1;
    return 0;
}
void NRF_SetRxMode()
{
    NRF_CE=0;
    reg_write(0, 59);
    NRF_CE=1;
}
void NRF_SetTxMode()
{
    NRF_CE=0;
    reg_write(0, 10);
    NRF_CE=1;
}
void NRF_SetChannel(unsigned char ch)
{
    NRF_CE=0;
    reg_write(5, ch);
    NRF_CE=1;
}
void NRF_SetPower(unsigned char p)
{
    NRF_CE=0;
    switch (p)
{
case 0:
        reg_write(6, 1);
        break;
case 1:
        reg_write(6, 3);
        break;
case 2:
        reg_write(6, 5);
        break;
case 3:
default:
        reg_write(6, 7);
        break;
    }
    NRF_CE=1;
}
void NRF_SetAddress(unsigned char *addr)
{
    unsigned char i;
    for (i=0; (i<5); i++)
        current_addr[i]=addr[i];
    NRF_CSN=0;
    spi_rw((32|16));
    for (i=0; (i<5); i++)
        spi_rw(addr[i]);
    NRF_CSN=1;
    NRF_CSN=0;
    spi_rw((32|10));
    for (i=0; (i<5); i++)
        spi_rw(addr[i]);
    NRF_CSN=1;
}
void NRF_Tx(unsigned char *buf, unsigned char len)
{
    NRF_CE=0;
    reg_write(7, 112);
    NRF_SetTxMode();
    fifo_write(buf, len);
    NRF_CE=1;
}
unsigned char NRF_Rx(unsigned char *buf, unsigned char len)
{
    unsigned char status;
    status=reg_read(7);
    if ((status&64))
        {
            fifo_read(buf, len);
            reg_write(7, 64);
            return 1;
        }
    return 0;
}
unsigned char NRF_Irq()
{
    return (NRF_IRQ==0) ? 1 : 0;
}
void NRF_ClearIrq()
{
    reg_write(7, 112);
}
static void i2c_delay()
{
    unsigned char i = 3;
    while (i--)
        {
        }
}
void I2C_Init()
{
    do
        {
            P3M0|=(1<<4);
            P3M1|=(1<<4);
        }
    while (0);
    do
        {
            P3M0|=(1<<5);
            P3M1|=(1<<5);
        }
    while (0);
    IMU_SCL=1;
    IMU_SDA=1;
}
unsigned char I2C_Start()
{
    IMU_SDA=1;
    i2c_delay();
    IMU_SCL=1;
    i2c_delay();
    IMU_SDA=0;
    i2c_delay();
    IMU_SCL=0;
    i2c_delay();
    return 0;
}
void I2C_Stop()
{
    IMU_SDA=0;
    i2c_delay();
    IMU_SCL=1;
    i2c_delay();
    IMU_SDA=1;
    i2c_delay();
}
unsigned char I2C_WriteByte(unsigned char dat)
{
    unsigned char i;
    for (i=0; (i<8); i++)
        {
            if ((dat&128))
                IMU_SDA=1;
            else
                IMU_SDA=0;
            dat<<=1;
            i2c_delay();
            IMU_SCL=1;
            i2c_delay();
            IMU_SCL=0;
            i2c_delay();
        }
    IMU_SDA=1;
    i2c_delay();
    IMU_SCL=1;
    i2c_delay();
    i=IMU_SDA;
    IMU_SCL=0;
    i2c_delay();
    return (i==0) ? 0 : 1;
}
unsigned char I2C_ReadByte(unsigned char ack)
{
    unsigned char i;
    unsigned char dat = 0;
    IMU_SDA=1;
    for (i=0; (i<8); i++)
        {
            dat<<=1;
            IMU_SCL=1;
            i2c_delay();
            dat|=1;
            IMU_SCL=0;
            i2c_delay();
        }
    if (ack)
        IMU_SDA=0;
    else
        IMU_SDA=1;
    i2c_delay();
    IMU_SCL=1;
    i2c_delay();
    IMU_SCL=0;
    i2c_delay();
    IMU_SDA=1;
    return dat;
}
unsigned char I2C_WriteReg(unsigned char dev_addr, unsigned char reg_addr, unsigned char dat)
{
    I2C_Start();
    if (I2C_WriteByte((dev_addr<<1)))
        return 1;
    if (I2C_WriteByte(reg_addr))
        return 1;
    if (I2C_WriteByte(dat))
        return 1;
    I2C_Stop();
    return 0;
}
unsigned char I2C_ReadReg(unsigned char dev_addr, unsigned char reg_addr, unsigned char *dat)
{
    I2C_Start();
    if (I2C_WriteByte((dev_addr<<1)))
        return 1;
    if (I2C_WriteByte(reg_addr))
        return 1;
    I2C_Start();
    if (I2C_WriteByte(((dev_addr<<1)|1)))
        return 1;
    (*dat)=I2C_ReadByte(0);
    I2C_Stop();
    return 0;
}
unsigned char I2C_ReadRegs(unsigned char dev_addr, unsigned char reg_addr, unsigned char *buf, unsigned char len)
{
    unsigned char i;
    if ((len==0))
        return 0;
    I2C_Start();
    if (I2C_WriteByte((dev_addr<<1)))
        return 1;
    if (I2C_WriteByte(reg_addr))
        return 1;
    I2C_Start();
    if (I2C_WriteByte(((dev_addr<<1)|1)))
        return 1;
    for (i=0; (i<len); i++)
        {
            buf[i]=I2C_ReadByte((i<(len-1)) ? 1 : 0);
        }
    I2C_Stop();
    return 0;
}
