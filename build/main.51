void UART_SendNum(unsigned long num, unsigned char base)
{
    signed char buf[12];
    unsigned char i = 0;
    if ((num==0))
        {
            UART_SendByte('0');
            return;
        }
    while ((num>0))
        {
            unsigned char d = (unsigned char)(num%base);
            buf[i++]=(d<10) ? ('0'+d) : (('A'+d)-10);
            num/=base;
        }
    while ((i>0))
        {
            UART_SendByte(buf[--i]);
        }
}
void UART_SendFloat(float f, unsigned char dec)
{
    long int_part;
    unsigned long frac_part;
    unsigned char i;
    if ((f<0))
        {
            UART_SendByte('-');
            f=(0-f);
        }
    int_part=(long)f;
    UART_SendNum((unsigned long)int_part, 10);
    UART_SendByte('.');
    f-=(float)int_part;
    for (i=0; (i<dec); i++)
        f*=10;
    frac_part=(unsigned long)f;
    UART_SendNum(frac_part, 10);
}
