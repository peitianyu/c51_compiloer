static float q0 = 1;
static float q1 = 0;
static float q2 = 0;
static float q3 = 0;
static float roll = 0;
static float pitch = 0;
static float yaw = 0;
static float gyro_offset_x = 0;
static float gyro_offset_y = 0;
static float gyro_offset_z = 0;
static int bytes_to_s16(unsigned char h, unsigned char l)
{
    return (int)(((int)h<<8)|l);
}
static float inv_sqrt(float x)
{
    return (1/sqrt(x));
}
unsigned char MPU6050_Init()
{
    unsigned char val;
    unsigned char retry = 10;
    while (retry--)
        {
            if ((I2C_ReadReg(104, 117, &val)==0))
                {
                    if (((val==104)||(val==112)))
                        break;
                }
        }
    if ((retry==0))
        return 1;
    I2C_WriteReg(104, 107, 128);
    for (val=0; (val<50); val++)
        {
        }
    I2C_WriteReg(104, 107, 0);
    I2C_WriteReg(104, 25, 0);
    I2C_WriteReg(104, 26, 1);
    I2C_WriteReg(104, 27, 8);
    I2C_WriteReg(104, 28, 8);
    I2C_WriteReg(104, 56, 1);
    return 0;
}
unsigned char MPU6050_ReadAll(struct MPU6050_Data_t *d)
{
    unsigned char buf[14];
    if (I2C_ReadRegs(104, 59, buf, 14))
        {
            return 1;
        }
    d->accel_x=bytes_to_s16(buf[0], buf[1]);
    d->accel_y=bytes_to_s16(buf[2], buf[3]);
    d->accel_z=bytes_to_s16(buf[4], buf[5]);
    d->temp=bytes_to_s16(buf[6], buf[7]);
    d->gyro_x=bytes_to_s16(buf[8], buf[9]);
    d->gyro_y=bytes_to_s16(buf[10], buf[11]);
    d->gyro_z=bytes_to_s16(buf[12], buf[13]);
    return 0;
}
float MPU6050_TempToCelsius(int raw)
{
    return (((float)raw/340)+36.53);
}
void MPU6050_MahonyUpdate(struct MPU6050_Data_t *d, float dt)
{
    float recipNorm;
    float gx;
    float gy;
    float gz;
    float ax;
    float ay;
    float az;
    float halfvx;
    float halfvy;
    float halfvz;
    float halfex;
    float halfey;
    float halfez;
    static float __sloc_0 = 0;
    static float __sloc_1 = 0;
    static float __sloc_2 = 0;
    float qa = q0;
    float qb = q1;
    float qc = q2;
    gx=(d->gyro_x-gyro_offset_x)*0.000133;
    gy=(d->gyro_y-gyro_offset_y)*0.000133;
    gz=(d->gyro_z-gyro_offset_z)*0.000133;
    ax=(d->accel_x/8192);
    ay=(d->accel_y/8192);
    az=(d->accel_z/8192);
    recipNorm=inv_sqrt(((ax*ax+ay*ay)+az*az));
    ax*=recipNorm;
    ay*=recipNorm;
    az*=recipNorm;
    halfvx=(q1*q3-q0*q2);
    halfvy=(q0*q1+q2*q3);
    halfvz=((q0*q0-0.5)+q3*q3);
    halfex=(ay*halfvz-az*halfvy);
    halfey=(az*halfvx-ax*halfvz);
    halfez=(ax*halfvy-ay*halfvx);
    __sloc_0+=0.05*halfex*dt;
    __sloc_1+=0.05*halfey*dt;
    __sloc_2+=0.05*halfez*dt;
    gx+=(__sloc_0+2*halfex);
    gy+=(__sloc_1+2*halfey);
    gz+=(__sloc_2+2*halfez);
    q0+=(((0-qb)*gx-qc*gy)-q3*gz)*0.5*dt;
    q1+=((qa*gx+qc*gz)-q3*gy)*0.5*dt;
    q2+=((qa*gy-qb*gz)+q3*gx)*0.5*dt;
    q3+=((qa*gz+qb*gy)-qc*gx)*0.5*dt;
    recipNorm=inv_sqrt((((q0*q0+q1*q1)+q2*q2)+q3*q3));
    q0*=recipNorm;
    q1*=recipNorm;
    q2*=recipNorm;
    q3*=recipNorm;
}
void MPU6050_GetEuler(struct Euler_t *e)
{
    roll=atan2(2*(q0*q1+q2*q3), (1-2*(q1*q1+q2*q2)));
    roll*=57.2958;
    pitch=asin(2*(q0*q2-q3*q1));
    pitch*=57.2958;
    yaw=atan2(2*(q0*q3+q1*q2), (1-2*(q2*q2+q3*q3)));
    yaw*=57.2958;
    e->roll=roll;
    e->pitch=pitch;
    e->yaw=yaw;
}
